{
  "schema": "CDF_CONFIG_SM_ANSA_V1",
  "seed": 20260506,
  "unit": "mm",
  "num_samples": 64,
  "dataset_profile": "sm_entity_v2_compact",
  "global_mesh_policy": {
    "h0_mm": 3.0,
    "h_min_mm": 0.5,
    "h_max_mm": 8.0,
    "growth_rate": 1.25,
    "quality_profile": "AMG_QA_SHELL_V2"
