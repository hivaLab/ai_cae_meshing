  "ansa_oracle": {
    "enabled": true,
    "ansa_executable": "${ANSA_EXECUTABLE}",
    "size_field_batch_script": "cad_dataset_factory/cdf/oracle/ansa_scripts/cdf_ansa_size_field.py",
    "quality_profile": "AMG_QA_SHELL_V2",
    "solver_deck": "NASTRAN",
