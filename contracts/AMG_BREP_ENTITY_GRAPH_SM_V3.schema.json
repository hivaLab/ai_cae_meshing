    "face_feature_columns": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "edge_feature_columns": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "coedge_feature_columns": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "vertex_feature_columns": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  },
  "additionalProperties": false
}
