{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AMG_CONFIG_SM_V1.schema.json",
  "title": "AMG_CONFIG_SM_V1",
  "type": "object",
  "required": [
    "schema_version",
    "unit",
    "mesh_policy",
    "model_pipeline",
    "ansa"
  ],
  "properties": {
    "schema_version": {"const": "AMG_CONFIG_SM_V1"},
    "unit": {"const": "mm"},
    "mesh_policy": {
      "type": "object",
      "required": ["h0_mm", "h_min_mm", "h_max_mm", "growth_rate", "quality_profile"],
      "properties": {
        "h0_mm": {"type": "number", "exclusiveMinimum": 0},
        "h_min_mm": {"type": "number", "exclusiveMinimum": 0},
        "h_max_mm": {"type": "number", "exclusiveMinimum": 0},
        "growth_rate": {"type": "number", "minimum": 1},
        "quality_profile": {"const": "AMG_QA_SHELL_V2"}
      },
      "additionalProperties": false
    },
    "model_pipeline": {
      "type": "object",
      "required": ["part_classifier", "entity_segmentation", "quality_surrogate"],
      "properties": {
        "part_classifier": {"type": "string"},
        "entity_segmentation": {"type": "string"},
        "quality_surrogate": {"type": "string"}
      },
      "additionalProperties": false
    },
    "ansa": {
      "type": "object",
      "required": ["batch_session", "quality_template", "export_solver"],
      "properties": {
        "batch_session": {"const": "AMG_SHELL_CONST_THICKNESS_V2"},
        "quality_template": {"const": "AMG_QA_SHELL_V2"},
        "export_solver": {"const": "NASTRAN"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
