{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CDF_CONFIG_SM_ANSA_V1.schema.json",
  "title": "CDF_CONFIG_SM_ANSA_V1",
  "type": "object",
  "required": [
    "schema",
    "seed",
    "unit",
    "num_samples",
    "dataset_profile",
    "global_mesh_policy",
    "part_sampling",
    "validation",
    "ansa_oracle"
  ],
  "properties": {
    "schema": {"const": "CDF_CONFIG_SM_ANSA_V1"},
    "seed": {"type": "integer"},
    "unit": {"const": "mm"},
    "num_samples": {"type": "integer", "minimum": 1},
    "dataset_profile": {"enum": ["sm_entity_v2_compact"]},
    "global_mesh_policy": {
      "type": "object",
      "required": ["h0_mm", "h_min_mm", "h_max_mm", "growth_rate", "quality_profile"],
      "properties": {
        "h0_mm": {"type": "number", "exclusiveMinimum": 0},
        "h_min_mm": {"type": "number", "exclusiveMinimum": 0},
        "h_max_mm": {"type": "number", "exclusiveMinimum": 0},
        "growth_rate": {"type": "number", "minimum": 1},
        "quality_profile": {"const": "AMG_QA_SHELL_V2"}
      },
      "additionalProperties": false
    },
    "part_sampling": {"type": "object"},
    "validation": {"type": "object"},
    "ansa_oracle": {"type": "object"}
  },
  "additionalProperties": false
}
