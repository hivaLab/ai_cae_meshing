{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CDF_FACE_SEGMENTATION_SM_V2.schema.json",
  "title": "CDF_FACE_SEGMENTATION_SM_V2",
  "type": "object",
  "required": ["schema_version", "sample_id", "labels"],
  "properties": {
    "schema_version": {"const": "CDF_FACE_SEGMENTATION_SM_V2"},
    "sample_id": {"type": "string", "minLength": 1},
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["face_signature_id", "semantic_label"],
        "properties": {
          "face_signature_id": {"type": "string", "minLength": 1},
          "semantic_label": {
            "enum": ["BASE_PANEL", "FLANGE", "BEND", "HOLE_WALL", "SLOT_WALL", "CUTOUT_WALL", "SIDE_WALL", "OTHER"]
          },
          "instance_id": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
