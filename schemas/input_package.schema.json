{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AMG input package manifest",
  "type": "object",
  "required": ["job_id", "schema_version", "units", "geometry", "metadata"],
  "properties": {
    "job_id": {"type": "string", "minLength": 1},
    "schema_version": {"type": "string"},
    "units": {"const": "mm"},
    "geometry": {
      "type": "object",
      "required": ["assembly_step"],
      "properties": {
        "assembly_step": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "required": ["product_tree", "part_attributes", "material_library", "connections", "mesh_profile"],
      "properties": {
        "product_tree": {"type": "string"},
        "part_attributes": {"type": "string"},
        "material_library": {"type": "string"},
        "connections": {"type": "string"},
        "mesh_profile": {"type": "string"}
      }
    }
  },
  "additionalProperties": true
}
