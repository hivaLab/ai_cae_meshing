{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Material library",
  "type": "object",
  "required": ["materials"],
  "properties": {
    "materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["material_id", "name", "young_modulus", "poisson_ratio", "density"],
        "properties": {
          "material_id": {"type": "string"},
          "name": {"type": "string"},
          "young_modulus": {"type": "number", "exclusiveMinimum": 0},
          "poisson_ratio": {"type": "number", "minimum": 0, "maximum": 0.5},
          "density": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    }
  },
  "additionalProperties": true
}
