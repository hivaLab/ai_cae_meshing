{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mesh recipe",
  "type": "object",
  "required": ["recipe_id", "sample_id", "backend", "part_strategies", "size_fields", "refinement_zones", "connections", "guard"],
  "properties": {
    "recipe_id": {"type": "string"},
    "sample_id": {"type": "string"},
    "backend": {"enum": ["SYNTHETIC_ORACLE", "ANSA_BATCH"]},
    "part_strategies": {"type": "array"},
    "size_fields": {"type": "array"},
    "refinement_zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["zone_uid", "target_type", "target_uid", "size_mm", "growth_rate", "preserve_boundary", "ansa_control_type", "reason"],
        "properties": {
          "zone_uid": {"type": "string"},
          "target_type": {"enum": ["part", "face", "edge", "feature", "contact_candidate", "connection"]},
          "target_uid": {"type": "string"},
          "size_mm": {"type": "number", "exclusiveMinimum": 0},
          "growth_rate": {"type": "number", "exclusiveMinimum": 0},
          "preserve_boundary": {"type": "boolean"},
          "ansa_control_type": {"type": "string"},
          "reason": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "connections": {"type": "array"},
    "guard": {"type": "object"}
  },
  "additionalProperties": true
}
