{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Product tree",
  "type": "object",
  "required": ["assembly_id", "root_part_uid", "parts"],
  "properties": {
    "assembly_id": {"type": "string"},
    "root_part_uid": {"type": "string"},
    "parts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["part_uid", "name", "parent_uid", "transform"],
        "properties": {
          "part_uid": {"type": "string"},
          "name": {"type": "string"},
          "parent_uid": {"type": ["string", "null"]},
          "transform": {"type": "array", "minItems": 16, "maxItems": 16, "items": {"type": "number"}}
        }
      }
    }
  },
  "additionalProperties": true
}
