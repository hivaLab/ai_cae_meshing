{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Real CAD/Mesh training dataset submission manifest",
  "type": "object",
  "required": ["sample_id", "required_artifacts", "acceptance"],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "required_artifacts": {
      "type": "object",
      "required": ["cad_step", "ansa_database", "acceptance_csv", "quality_criteria_yaml"],
      "properties": {
        "cad_step": {"const": "cad/raw.step"},
        "ansa_database": {"const": "ansa/final.ansa"},
        "acceptance_csv": {"const": "metadata/acceptance.csv"},
        "quality_criteria_yaml": {"const": "metadata/quality_criteria.yaml"}
      }
    },
    "optional_artifacts": {
      "type": "object",
      "properties": {
        "solver_bdf": {"const": "solver/final.bdf"},
        "ansa_quality_report": {"type": "string"}
      },
      "additionalProperties": true
    },
    "acceptance": {
      "type": "object",
      "required": ["allowed_statuses"],
      "properties": {
        "allowed_statuses": {
          "type": "array",
          "items": {"enum": ["accepted", "rejected", "needs_manual_review", "unknown"]},
          "minItems": 4
        }
      }
    },
    "material_constants_required": {"const": false}
  },
  "additionalProperties": true
}
